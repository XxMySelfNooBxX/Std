    replacement_chunks {
      target_content: "  const Section = ({ title, icon: Icon, items, colorClass, bgClass, textClass }: any) => (\n    <div className=\"flex flex-col bg-white border border-neutral-200/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow\">\n      <div className={`px-5 py-4 border-b border-neutral-100 flex items-center space-x-2.5 ${bgClass}`}>\n        <Icon className={`w-4 h-4 ${textClass}`} />\n        <h3 className=\"font-semibold text-sm text-neutral-800 tracking-tight\">{title}</h3>\n        <span className=\"ml-auto text-xs font-semibold px-2 py-0.5 rounded-full bg-white/60 text-neutral-700 shadow-sm\">\n          {items.length}\n        </span>\n      </div>\n      <div className=\"p-2.5 space-y-1.5 bg-white flex-1 min-h-[140px] overflow-y-auto\">\n        {items.length === 0 ? (\n          <div className=\"h-full flex flex-col items-center justify-center text-neutral-300 italic py-6 space-y-2\">\n            <div className=\"w-8 h-8 rounded-full bg-neutral-50 flex items-center justify-center\">\n              <span className=\"text-[10px] uppercase font-bold text-neutral-400 opacity-50\">Empty</span>\n            </div>\n          </div>\n        ) : (\n          items.map((t: Task) => (\n            <div key={t.id} className=\"group px-3.5 py-3 bg-white hover:bg-neutral-50 rounded-xl transition-all border border-transparent hover:border-neutral-200 cursor-default\">\n              <div className=\"text-sm text-neutral-800 font-medium leading-snug\">{t.title}</div>\n              {t.estimatedMinutes && (\n                <div className=\"text-xs font-medium text-neutral-400 mt-1.5 flex items-center\">\n                  <Clock className=\"w-3.5 h-3.5 mr-1\" />\n                  {t.estimatedMinutes}m est.\n                </div>\n              )}\n            </div>\n          ))\n        )}\n      </div>\n    </div>\n  );\n\n  return (\n    <div className=\"grid grid-cols-1 md:grid-cols-3 gap-5\">\n      <Section title=\"Urgent & Critical\" icon={AlertCircle} items={urgent} bgClass=\"bg-red-50/50\" textClass=\"text-red-500\" />\n      <Section title=\"High Dependency\" icon={Layers} items={dependency} bgClass=\"bg-amber-50/50\" textClass=\"text-amber-500\" />\n      <Section title=\"Micro-Tasks\" icon={Search} items={micro} bgClass=\"bg-emerald-50/50\" textClass=\"text-emerald-500\" />\n    </div>"
      replacement_content: "  const Section = ({ title, items, bgClass, borderClass, badgeBgClass, badgeText, countClass }: any) => (\n    <div className={`${bgClass} ${borderClass} border p-4 rounded-xl flex flex-col h-full`}>\n      <div className=\"flex justify-between items-center mb-3\">\n        <span className={`text-[10px] font-bold ${badgeBgClass} text-white px-2 py-0.5 rounded shadow-sm`}>{badgeText}</span>\n        <span className={`text-xs ${countClass} font-medium`}>{items.length} Items</span>\n      </div>\n      <div className=\"space-y-2 flex-1 min-h-[100px] max-h-[200px] overflow-y-auto pr-1\">\n        {items.length === 0 ? (\n          <div className=\"h-full flex flex-col items-center justify-center text-slate-400 italic py-4\">\n            <span className=\"text-[10px] uppercase font-bold opacity-50\">Empty</span>\n          </div>\n        ) : (\n          items.map((t: Task) => (\n            <div key={t.id} className={`bg-white p-2.5 rounded border text-xs shadow-sm flex flex-col gap-1 transition-all hover:shadow cursor-default ${borderClass.replace(\'100\', \'200\')}`}>\n              <div className=\"text-slate-800 font-medium leading-snug\">{t.title}</div>\n              {t.estimatedMinutes && (\n                <div className=\"text-[10px] font-medium text-slate-400 flex items-center\">\n                  <Clock className=\"w-3 h-3 mr-1\" />\n                  {t.estimatedMinutes}m\n                </div>\n              )}\n            </div>\n          ))\n        )}\n      </div>\n    </div>\n  );\n\n  return (\n    <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n      <Section title=\"Urgent & Critical\" badgeText=\"URGENT\" items={urgent} bgClass=\"bg-red-50\" borderClass=\"border-red-100\" badgeBgClass=\"bg-red-500\" countClass=\"text-red-700\" />\n      <Section title=\"High Dependency\" badgeText=\"DEPENDENCY\" items={dependency} bgClass=\"bg-amber-50\" borderClass=\"border-amber-100\" badgeBgClass=\"bg-amber-500\" coun