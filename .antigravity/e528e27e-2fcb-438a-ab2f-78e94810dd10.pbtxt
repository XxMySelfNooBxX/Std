    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "  if (schedule.length === 0) {\n    return (\n        <div className=\"flex flex-col items-center justify-center h-[250px] md:h-full text-slate-400 bg-white rounded-2xl border border-dashed border-slate-200\">\n            <Calendar className=\"w-10 h-10 mb-4 opacity-20\" />\n            <p className=\"text-sm font-medium tracking-tight\">Timeline Awaiting Generation...</p>\n        </div>\n    );\n  }\n\n  return (\n    <div className=\"bg-white border border-slate-200 rounded-2xl p-6 relative h-[350px] md:h-full overflow-y-auto shadow-sm\">\n      <div className=\"ml-16 border-l border-slate-100 relative min-h-full py-2\">\n        {schedule.map((block) => {\n          const task = tasks.find(t => t.id === block.taskId);\n          \n          let blockClasses = \"bg-slate-50 border-slate-300\";\n          let titleClasses = \"text-slate-800\";\n          let subtitleClasses = \"text-slate-500\";\n\n          if (block.type === \'work\') {\n            blockClasses = \"bg-blue-600/10 border-blue-600\";\n            titleClasses = \"text-blue-800\";\n            subtitleClasses = \"text-blue-600\";\n            if (task?.category === \'Urgent & Critical\') {\n              blockClasses = \"bg-red-600/10 border-red-600\";\n              titleClasses = \"text-red-800\";\n              subtitleClasses = \"text-red-600\";\n            } else if (task?.category === \'High Dependency\') {\n              blockClasses = \"bg-amber-600/10 border-amber-600\";\n              titleClasses = \"text-amber-800\";\n              subtitleClasses = \"text-amber-600\";\n            }\n          }\n          \n          return (\n            <div key={block.id} className=\"relative mb-6\">\n              {/* Timeline dot */}\n              <div className=\"absolute -left-[5px] top-4 w-2.5 h-2.5 rounded-full bg-slate-300 border-2 border-white shadow-sm z-10\" />\n              \n              {/* Time Label */}\n              <div className=\"absolute -left-[4.5rem] top-3 text-[10px] text-slate-400 font-mono w-14 text-right pr-2\">\n                {format(parseISO(block.startTime), \'HH:mm\')}\n              </div>\n\n              {/* Block Content */}\n              <div className=\"ml-4 flex-1\">\n                <div className={`p-3 rounded-r shadow-sm border-l-4 ${blockClasses} transition-all hover:shadow-md`}>\n                  <div className=\"flex justify-between items-start\">\n                    <span className={`text-xs font-bold uppercase tracking-tight ${titleClasses}`}>\n                      {block.title}\n                    </span>\n                    <span className=\"text-[10px] bg-white/50 px-1.5 py-0.5 rounded font-mono text-slate-500 shrink-0 ml-2\">\n                       {format(parseISO(block.startTime), \'h:mm a\')} - {format(parseISO(block.endTime), \'h:mm a\')}\n                    </span>\n                  </div>\n                  \n                  {task && (\n                    <p className={`text-[10px] mt-1 line-clamp-1 font-medium ${subtitleClasses}`}>\n                      Focus: {task.title}\n                    </p>\n                  )}\n                  {block.type !== \'work\' && (\n                    <p className={`text-[10px] mt-1 line-clamp-1 italic ${subtitleClasses}`}>\n                      Reserved for decompression.\n                    </p>\n                  )}\n                </div>\n              </div>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );"
      replacement_content: "  if (schedule.length === 0) {\n    return (\n        <div className=\"flex flex-col items-center justify-center h-[250px] md:h-full text-zinc-600 bg-zinc-900/50 rounded-2xl border border-dashed border-white/10\">\n            <Calendar className=\"w-10 h-10 mb-4 opacity-20\" />\n            <p className=\"text-sm font-medium tracking-tight\">Timeline Awaiting Generation...</p>\n        </div>\n    );\n  }\n\n  return (\n    <div className=\"bg-zinc-900/50 border border-white/10 rounded-2xl p-6 relative h-[350px] md:h-full overflow-y-auto\">\n      <div className=\"ml-16 border-l border-white/10 relative min-h-full py-2\">\n        {schedule.map((block) => {\n          const task = tasks.find(t => t.id === block.taskId);\n          \n          let blockClasses = \"bg-zinc-800/30 border-zinc-700/50\";\n          let titleClasses = \"text-zinc-300\";\n          let subtitleClasses = \"text-zinc-500\";\n\n          if (block.type === \'work\') {\n            blockClasses = \"bg-indigo-500/10 border-indigo-500/50\";\n            titleClasses = \"text-indigo-400\";\n            subtitleClasses = \"text-indigo-600\";\n            if (task?.category === \'Urgent & Critical\') {\n              blockClasses = \"bg-red-500/10 border-red-500/50\";\n              titleClasses = \"text-red-400\";\n              subtitleClasses = \"text-red-600/80\";\n            } else if (task?.category === \'High Dependency\') {\n              blockClasses = \"bg-amber-500/10 border-amber-500/50\";\n              titleClasses = \"text-amber-400\";\n              subtitleClasses = \"text-amber-600/80\";\n            }\n          }\n          \n          return (\n            <div key={block.id} className=\"relative mb-6\">\n              {/* Timeline dot */}\n              <div className=\"absolute -left-[5px] top-4 w-2.5 h-2.5 rounded-full bg-zinc-700 border-2 border-zinc-900 z-10\" />\n              \n              {/* Time Label */}\n              <div className=\