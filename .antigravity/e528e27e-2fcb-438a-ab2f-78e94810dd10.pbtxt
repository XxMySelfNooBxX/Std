    replacement_chunks {
      target_content: "  if (schedule.length === 0) {\n    return (\n        <div className=\"flex flex-col items-center justify-center h-[350px] text-neutral-400 bg-white rounded-2xl border border-dashed border-neutral-200\">\n            <Calendar className=\"w-10 h-10 mb-4 opacity-20\" />\n            <p className=\"text-sm font-medium tracking-tight\">Timeline Awaiting Generation...</p>\n        </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-0 py-4\">\n      {schedule.map((block, idx) => {\n        const isFirst = idx === 0;\n        const isLast = idx === schedule.length - 1;\n        const Icon = block.type === \'break\' ? Coffee : block.type === \'buffer\' ? Zap : Briefcase;\n        const task = tasks.find(t => t.id === block.taskId);\n        \n        return (\n          <div key={block.id} className=\"flex group relative\">\n            {/* Timeline Line */}\n            <div className=\"flex flex-col items-center mr-6 ml-2 relative\">\n              <div className={`w-[2px] h-full ${isFirst ? \'bg-gradient-to-b from-transparent to-neutral-200\' : \'bg-neutral-200\'} transition-colors group-hover:bg-neutral-300`} />\n              <div className={`absolute top-1/2 -translate-y-1/2 w-10 h-10 shrink-0 rounded-full flex items-center justify-center shadow-sm border-[3px] border-white z-10 transition-transform group-hover:scale-110\n                ${block.type === \'break\' ? \'bg-orange-50 text-orange-500 group-hover:bg-orange-100\' : \n                  block.type === \'buffer\' ? \'bg-blue-50 text-blue-500 group-hover:bg-blue-100\' : \n                  \'bg-neutral-900 text-white shadow-neutral-900/20\'}\n              `}>\n                <Icon className=\"w-4 h-4\" />\n              </div>\n              <div className={`w-[2px] h-full ${isLast ? \'bg-gradient-to-b from-neutral-200 to-transparent\' : \'bg-neutral-200\'} transition-colors group-hover:bg-neutral-300`} />\n            </div>\n\n            {/* Block Content */}\n            <div className=\"py-4 flex-1\">\n              <div className={`bg-white border rounded-2xl p-5 transition-all shadow-sm group-hover:shadow-md ${block.type === \'work\' ? \'border-neutral-200 group-hover:border-neutral-300\' : \'border-dashed border-neutral-200 opacity-90\'}`}>\n                <div className=\"flex justify-between items-start mb-2\">\n                  <h4 className={`font-semibold text-base tracking-tight ${block.type === \'work\' ? \'text-neutral-900\' : \'text-neutral-600\'}`}>\n                    {block.title}\n                  </h4>\n                  <span className={`text-xs font-bold font-mono px-2.5 py-1 rounded-md ml-3 shrink-0 ${block.type === \'work\' ? \'bg-neutral-100 text-neutral-600\' : \'bg-transparent text-neutral-400\'}`}>\n                    {format(parseISO(block.startTime), \'h:mm a\')} <span className=\"opacity-50 mix-blend-multiply mx-1\">\342\200\223</span> {format(parseISO(block.endTime), \'h:mm a\')}\n                  </span>\n                </div>\n                {task && (\n                  <div className=\"mt-3 text-sm font-medium text-neutral-500 flex items-center bg-neutral-50/50 p-2.5 rounded-lg border border-neutral-100\">\n                    <span className=\"w-2 h-2 rounded-full bg-emerald-400 mr-2 shadow-[0_0_8px_rgba(52,211,153,0.8)]\" />\n                    <span><span className=\"opacity-60 font-semibold uppercase text-[10px] tracking-wider mr-2\">Focus:</span> {task.title}</span>\n                  </div>\n                )}\n                {block.type !== \'work\' && (\n                  <div className=\"mt-2 text-sm text-neutral-400 italic\">\n                    Time reserved to breathe and decompress.\n                  </div>\n                )}\n              </div>\n            </div>\n          </div>\n        );\n      })}\n    </div>\n  );"
      replacement_content: "  if (schedule.length === 0) {\n    return (\n        <div className=\"flex flex-col items-center justify-center h-[250px] md:h-full text-slate-400 bg-white rounded-2xl border border-dashed border-slate-200\">\n            <Calendar className=\"w-10 h-10 mb-4 opacity-20\" />\n            <p className=\"text-sm font-medium tracking-tight\">Timeline Awaiting Generation...</p>\n        </div>\n    );\n  }\n\n  return (\n    <div className=\"bg-white border border-slate-200 rounded-2xl p-6 relative h-[350px] md:h-full overflow-y-auto shadow-sm\">\n      <div className=\"ml-16 border-l border-slate-100 relative min-h-full py-2\">\n        {schedule.map((block) => {\n          const task = tasks.find(t => t.id === block.taskId);\n          \n          let blockClasses = \"bg-slate-50 border-slate-300\";\n          let titleClasses = \"text-slate-800\";\n          let subtitleClasses = \"text-slate-500\";\n\n          if (block.type === \'work\') {\n            blockClasses = \"bg-blue-600/10 border-blue-600\";\n            titleClasses = \"text-blue-800\";\n            subtitleClasses = \"text-blue-600\";\n            if (task?.category === \'Urgent & Critical\') {\n              blockClasses = \"bg-red-600/10 border-red-600\";\n              titleClasses = \"text-red-800\";\n              subtitleClasses = \"text-red-600\";\n            } else if (task?.category === \'High Dependency\') {\n              blockClasses = \"bg-amber-600/10 border-amber-600\";\n              titleClasses = \"text-amber-800\";\n              subtitleClasses = \"text-amber-600\";\n            }\n          }\n          \n          return (\n            <div key={block.id} className=\"relative mb-6\">\n              {/* Timeline dot */}\n              <div className=\"absolute -left-[5px] top-4 w-2.5 h-2.5 rounded-full bg-slate-300 border-2 border-white shadow-sm z-10\" />\n              \n              {/* Time Label */}\n              <div className=\"absolute -left-[4.5rem] top-3 text-[10px] text-slate-400 font-mono w-14 text-right pr-2\">\n                {format(parseISO(block.startTime), \'HH:mm\')}\n              </div>\n\n              {/* Block Content */}\n              <div className=\"ml-4 flex-1\">\n                <div className={`p-3 rounded-r shadow-sm border-l-4 ${blockClasses} transition-all hover:shadow-md`}>\n                  <div className=\"flex justify-between items-start\">\n                    <span className={`text-xs font-bold uppercase tracking-tight ${titleClasses}`}>\n                      {block.title}\n                    </span>\n                    <span className=\"text-[10px] bg-white/50 px-1.5 py-0.5 rounded font-mono text-slate-500 shrink-0 ml-2\">\n                       {format(parseISO(block.startTime), \'h:mm a\')} - {format(parseISO(block.endTime), \'h:mm a\')}\n                    </span>\n                  </div>\n                  \n                  {task && (\n                    <p className={`text-[10px] mt-1 line-clamp-1 font-medium ${subtitleClasses}`}>\n                      Focus: {task.title}\n                    </p>\n                  )}\n                  {block.type !== \'work\' && (\n                    <p className={`text-[10px] mt-1 line-clamp-1 italic ${subtitleClasses}`}>\n                      Reserved for decompression.\n                    </p>\n                  )}\n                </div>\n              </div>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );"
